<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Header: Title & Close Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="serif"
            android:text="Lý do hủy đơn"
            android:textColor="@color/dark_green"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnCloseDialog"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close"
            android:padding="4dp"
            android:src="@drawable/ic_close_x" />

    </LinearLayout>

    <!-- Radio Options -->
    <RadioGroup
        android:id="@+id/rgCancelReasons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp">

        <RadioButton
            android:id="@+id/rbOption1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:paddingVertical="8dp"
            android:text="Thay đổi ý định mua hàng"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <RadioButton
            android:id="@+id/rbOption2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp"
            android:text="Tìm thấy nơi khác giá rẻ hơn"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <RadioButton
            android:id="@+id/rbOption3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp"
            android:text="Phí vận chuyển quá cao"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <RadioButton
            android:id="@+id/rbOption4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp"
            android:text="Thời gian giao hàng quá lâu"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <RadioButton
            android:id="@+id/rbOption5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp"
            android:text="Nhập sai thông tin"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <RadioButton
            android:id="@+id/rbOption6"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp"
            android:text="Khác"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

    </RadioGroup>

    <!-- Additional Note Field -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Ghi chú thêm (Không bắt buộc)"
        android:textColor="#675C53"
        android:textSize="12sp" />

    <EditText
        android:id="@+id/edtCancelNote"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_input"
        android:gravity="top"
        android:hint="Nhập lý do của bạn..."
        android:importantForAutofill="no"
        android:inputType="textMultiLine"
        android:padding="12dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/hint"
        android:textSize="13sp" />

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDismissCancel"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="Đóng"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            app:backgroundTint="#F0EBE3"
            app:cornerRadius="99dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmCancel"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Xác nhận hủy"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="@color/dark_green"
            app:cornerRadius="99dp" />

    </LinearLayout>

</LinearLayout>
