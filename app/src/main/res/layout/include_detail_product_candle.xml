<?xml version="1.0" encoding="utf-8" ?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_section"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="18dp"
>
    <androidx.cardview.widget.CardView
        android:layout_width="96dp"
        android:layout_height="96dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
    >
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Nến thơm Tinh Dầu"
            android:scaleType="centerCrop"
            android:src="@drawable/figma_cancelled_1_mockup"
        />
    </androidx.cardview.widget.CardView>
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="96dp"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:gravity="center_vertical"
        android:orientation="vertical"
    >
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nến thơm Tinh Dầu"
            android:textColor="#1A2821"
            android:textSize="16sp"
            android:textStyle="bold"
        />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Phân loại: Gỗ Thông &amp; Rêu"
            android:textColor="#434844"
            android:textSize="12sp"
        />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Số lượng: 2"
            android:textColor="#434844"
            android:textSize="12sp"
        />
    </LinearLayout>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="320.000đ"
        android:textColor="#1A2821"
        android:textSize="22sp"
    />
</LinearLayout>
