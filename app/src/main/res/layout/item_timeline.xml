<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingBottom="16dp">

    <!-- Timeline Indicator (Icon + Line) -->
    <LinearLayout
        android:layout_width="32dp"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivTimelineIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_check_circle_green" />

        <View
            android:id="@+id/viewTimelineLine"
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:layout_marginTop="4dp"
            android:background="#D6CEC4" />

    </LinearLayout>

    <!-- Timeline Text Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvTimelineTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/dark_green"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="Đã xác nhận" />

            <TextView
                android:id="@+id/tvTimelineTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#675C53"
                android:textSize="12sp"
                tools:text="20/06/2024 • 09:15" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvTimelineDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#675C53"
            android:textSize="13sp"
            android:visibility="gone"
            tools:text="Đơn hàng đang được shipper vận chuyển đến bạn."
            tools:visibility="visible" />

    </LinearLayout>

</LinearLayout>
