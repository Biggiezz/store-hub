<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F6F2"
    android:orientation="vertical">

    <FrameLayout
        android:id="@+id/fragmentAdminContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F9F6F2"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHome"
            style="@style/Widget.StoreHub.BottomNavButton"
            android:text="@string/nav_home"
            app:icon="@drawable/ic_home" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnProducts"
            style="@style/Widget.StoreHub.BottomNavButton"
            android:text="@string/nav_products"
            app:icon="@drawable/ic_products" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNews"
            style="@style/Widget.StoreHub.BottomNavButton"
            android:text="@string/nav_news"
            app:icon="@drawable/ic_news" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUsers"
            style="@style/Widget.StoreHub.BottomNavButton"
            android:text="@string/admin_users"
            app:icon="@drawable/ic_users" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStats"
            style="@style/Widget.StoreHub.BottomNavButton"
            android:text="@string/admin_stats"
            app:icon="@drawable/ic_stats" />

    </LinearLayout>

</LinearLayout>
