<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- Header StoreHub -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="26dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="serif"
            android:text="StoreHub"
            android:textColor="@color/dark_green"
            android:textSize="36sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeColor="#DDD8D2"
            app:strokeWidth="1dp">

            <ImageView
                android:id="@+id/imgAvatarHeader"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Avatar"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_avatar" />

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#C3C8C3" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="20dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:text="Đơn hàng của tôi"
            android:textColor="@color/dark_green"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- Horizontal Filter Chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipAll"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingHorizontal="16dp"
                    android:text="Tất cả"
                    android:textAllCaps="false"
                    android:textColor="@color/dark_green"
                    android:textSize="13sp"
                    app:backgroundTint="#E8DFD7"
                    app:cornerRadius="99dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipPending"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingHorizontal="16dp"
                    android:text="Chờ xác nhận"
                    android:textAllCaps="false"
                    android:textColor="#675C53"
                    android:textSize="13sp"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="99dp"
                    app:strokeColor="#D6CEC4"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipShipping"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingHorizontal="16dp"
                    android:text="Đang giao"
                    android:textAllCaps="false"
                    android:textColor="#675C53"
                    android:textSize="13sp"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="99dp"
                    app:strokeColor="#D6CEC4"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipCompleted"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingHorizontal="16dp"
                    android:text="Đã hoàn thành"
                    android:textAllCaps="false"
                    android:textColor="#675C53"
                    android:textSize="13sp"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="99dp"
                    app:strokeColor="#D6CEC4"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipCancelled"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingHorizontal="16dp"
                    android:text="Đã hủy"
                    android:textAllCaps="false"
                    android:textColor="#675C53"
                    android:textSize="13sp"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="99dp"
                    app:strokeColor="#D6CEC4"
                    app:strokeWidth="1dp" />

            </LinearLayout>

        </HorizontalScrollView>

        <!-- Orders RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvOrders"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="20dp"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingBottom="24dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_order" />

    </LinearLayout>

</LinearLayout>
