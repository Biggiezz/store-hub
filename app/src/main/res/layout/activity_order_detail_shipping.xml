<?xml version="1.0" encoding="utf-8" ?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/orderDetailRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/background"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="#1A2821"
        app:title="Chi tiết đơn hàng"
        app:titleTextColor="#1A2821" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="16dp"
            android:paddingEnd="20dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_detail_section_warm"
                android:orientation="vertical"
                android:padding="25dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/ic_car" />

                    <TextView
                        android:id="@+id/tvStatusTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#1A2821"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvStatusBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_status_dark"
                        android:gravity="center"
                        android:paddingHorizontal="12dp"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvOrderDetailCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:textColor="#434844"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvEstimatedDelivery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#675C53"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_section"
                android:orientation="vertical"
                android:padding="25dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lộ trình vận chuyển"
                    android:textColor="#1A2821"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="260dp"
                    android:layout_marginTop="28dp">

                    <View
                        android:layout_width="2dp"
                        android:layout_height="220dp"
                        android:layout_marginStart="11dp"
                        android:layout_marginTop="8dp"
                        android:background="#C3C8C3" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Step 1: Confirmed -->
                        <LinearLayout
                            android:id="@+id/layoutStepConfirmed"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/ivStepConfirmed"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:background="@drawable/bg_timeline_done"
                                android:padding="6dp"
                                android:src="@drawable/ic_active" />

                            <TextView
                                android:id="@+id/tvStepConfirmed"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:textColor="#1B1C1A"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Step 2: Out of Warehouse -->
                        <LinearLayout
                            android:id="@+id/layoutStepWarehouse"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/ivStepWarehouse"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:background="@drawable/bg_timeline_done"
                                android:padding="6dp"
                                android:src="@drawable/ic_order_done" />

                            <TextView
                                android:id="@+id/tvStepWarehouse"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:textColor="#1B1C1A"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Step 3: Delivering -->
                        <LinearLayout
                            android:id="@+id/layoutStepDelivering"
                            android:layout_width="match_parent"
                            android:layout_height="92dp"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/ivStepDelivering"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:background="@drawable/bg_timeline_active"
                                android:padding="5dp"
                                android:src="@drawable/ic_car_check" />

                            <TextView
                                android:id="@+id/tvStepDelivering"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:textColor="#1A2821"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Step 4: Completed -->
                        <LinearLayout
                            android:id="@+id/layoutStepCompleted"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/ivStepCompleted"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:background="@drawable/bg_timeline_pending"
                                android:padding="6dp" />

                            <TextView
                                android:id="@+id/tvStepCompleted"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:textColor="#434844"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>

            <include
                layout="@layout/include_shipping_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#ECE7DF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#F5F3EF"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:text="Sản phẩm"
                        android:textColor="#1A2821"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#ECE7DF" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvOrderProducts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:padding="16dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <include
                layout="@layout/include_detail_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp" />


            <TextView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_button"
                android:fontFamily="serif"
                android:gravity="center"
                android:text="Liên hệ hỗ trợ"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnCancelOrder"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_detail_secondary_button"
                android:gravity="center"
                android:text="Hủy đơn hàng"
                android:textColor="#434844"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
