<?xml version="1.0" encoding="utf-8" ?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
>
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:fontFamily="serif"
        android:text="Thông tin giao hàng"
        android:textColor="#1A2821"
        android:textSize="20sp"
        android:textStyle="bold"
    />
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_shipping_info_figma"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="21dp"
        android:paddingEnd="18dp"
        android:paddingBottom="21dp"
    >
        <TextView
            android:id="@+id/tvShippingNamePhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawableStart="@drawable/ic_detail_person"
            android:drawablePadding="12dp"
            android:text="Nguyễn Minh Tuấn  •  090 123 4567"
            android:textColor="#1B1C1A"
            android:textSize="14sp"
        />
        <TextView
            android:id="@+id/tvShippingAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:drawableStart="@drawable/ic_detail_location"
            android:drawablePadding="12dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="123 Đường Tự Do, Phường Bến Nghé, Quận 1"
            android:textColor="#434844"
            android:textSize="14sp"
        />
    </LinearLayout>
</LinearLayout>
