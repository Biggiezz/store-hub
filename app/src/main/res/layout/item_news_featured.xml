<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="24dp"
    android:background="@color/background">

    <!-- Container cho ảnh bài viết nổi bật (Có nhãn Nổi bật đè lên) -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="220dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/background">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/ivNewsImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                tools:src="@drawable/image_placeholder" />

            <!-- Nhãn Nổi Bật -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|left"
                android:layout_margin="16dp"
                android:background="@drawable/bg_featured_badge"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="NỔI BẬT"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold" />

        </FrameLayout>

    </androidx.cardview.widget.CardView>

    <!-- Nội dung Text bài viết -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="12dp"
        android:paddingHorizontal="4dp">

        <!-- Danh mục cố định -->
        <TextView
            android:id="@+id/tvFeaturedCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CÔNG NGHỆ &amp; ĐỜI SỐNG"
            android:textColor="#AAA49D"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginBottom="6dp" />

        <!-- Tiêu đề lớn -->
        <TextView
            android:id="@+id/tvNewsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:text="Tiêu đề bài viết nổi bật"
            android:textColor="@color/dark_green"
            android:textSize="22sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.15"
            android:layout_marginBottom="8dp" />

        <!-- Tóm tắt nội dung ngắn -->
        <TextView
            android:id="@+id/tvNewsDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Khám phá hành trình tìm kiếm vẻ đẹp và những trải nghiệm mới mẻ..."
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.2"
            android:ellipsize="end"
            android:maxLines="3"
            android:layout_marginBottom="8dp" />

        <!-- Thời gian đăng bài viết -->
        <TextView
            android:id="@+id/tvNewsTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 GIỜ TRƯỚC"
            android:textColor="#AAA49D"
            android:textSize="11sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
