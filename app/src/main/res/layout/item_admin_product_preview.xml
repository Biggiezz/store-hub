<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="7dp"
    android:background="@drawable/bg_card_section"
    android:clipToOutline="true"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/ivAdminProduct"
        android:layout_width="match_parent"
        android:layout_height="207dp"
        android:contentDescription="Ảnh sản phẩm"
        android:scaleType="centerCrop" />

    <TextView
        android:id="@+id/tvAdminProductCategory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:textColor="#5D615E"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvAdminProductName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="12dp"
        android:maxLines="1"
        android:textColor="#26332D"
        android:textSize="17sp" />

    <TextView
        android:id="@+id/tvAdminProductPrice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="7dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="13dp"
        android:textColor="#1D3027"
        android:textSize="17sp"
        android:textStyle="bold" />
</LinearLayout>
