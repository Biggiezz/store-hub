<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF9F7"
    android:id="@+id/management_reviews_layout"
    android:orientation="vertical">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#FFFEFC"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            app:tint="#24382F" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Quản lý Đánh giá"
            android:textColor="#26332D"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#ECE9E5" />

    <!-- Filter tabs -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#FFFEFC"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/layoutFilters"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:id="@+id/tvFilterAll"
                style="@style/Widget.StoreHub.AdminChip"
                android:text="Tất cả" />

            <TextView
                android:id="@+id/tvFilterUnanswered"
                style="@style/Widget.StoreHub.AdminChip"
                android:layout_marginStart="10dp"
                android:text="Chưa trả lời" />

            <TextView
                android:id="@+id/tvFilterAnswered"
                style="@style/Widget.StoreHub.AdminChip"
                android:layout_marginStart="10dp"
                android:text="Đã trả lời" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- Nội dung có thể cuộn -->
    <ScrollView
        android:id="@+id/scrollReviews"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:id="@+id/layoutReviewContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Review chưa trả lời -->
            <include
                android:id="@+id/reviewNguyenVanA"
                layout="@layout/item_review_unanswered" />

            <!-- Review đã trả lời -->
            <include
                android:id="@+id/reviewTranThiB"
                layout="@layout/item_review_answered" />

            <include
                android:id="@+id/reviewLeVanC"
                layout="@layout/item_review_unanswered" />

            <include
                android:id="@+id/reviewPhamThiD"
                layout="@layout/item_review_answered" />

            <include
                android:id="@+id/reviewHoangVanE"
                layout="@layout/item_review_unanswered" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>