<?xml version="1.0" encoding="utf-8" ?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FBF9F5" />
            <stroke android:width="1dp" android:color="#E5E5E1" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item android:width="4dp" android:gravity="start">
        <shape android:shape="rectangle">
            <solid android:color="#1A2821" />
            <corners android:topLeftRadius="12dp" android:bottomLeftRadius="12dp" />
        </shape>
    </item>
</layer-list>
